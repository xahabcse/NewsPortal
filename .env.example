# News Portal Environment Variables
# Copy this file to .env and update with your actual values

# Application Environment
ASPNETCORE_ENVIRONMENT=Production

# PostgreSQL Database Configuration
POSTGRES_USER=newsadmin
POSTGRES_PASSWORD=YourSecurePassword123_ChangeThis!
POSTGRES_DB=newsportal
POSTGRES_PORT=5432

# MongoDB Configuration
MONGO_USER=mongouser
MONGO_PASSWORD=MongoPassword123_ChangeThis!
MONGO_PORT=27017

# Redis Configuration
REDIS_PORT=6379

# Web Application Port
WEB_PORT=5000

# Optional: API Keys for News Fetching
# NEWS_API_KEY=your_newsapi_key
# GNEWS_API_KEY=your_gnews_key
# BING_SEARCH_API_KEY=your_bing_key
