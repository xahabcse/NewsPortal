# ============================================================================
# NewsPortal - Environment Configuration
# ============================================================================
# Copy this file to .env and update the values for your environment.
#
#   cp .env.example .env
#
# IMPORTANT: Never commit your .env file to version control.
# ============================================================================


# ----------------------------------------------------------------------------
# PostgreSQL — Main Relational Database
# ----------------------------------------------------------------------------
# Used by: docker-compose.yml, docker-compose.dev.yml,
#          docker-compose.monitoring.yml (postgres-exporter)

# Database superuser name
POSTGRES_USER=newsadmin

# Database superuser password
POSTGRES_PASSWORD=admin123

# Default database name created on first run
POSTGRES_DB=newsportal

# Host port mapped to the PostgreSQL container (default: 5432)
POSTGRES_PORT=5432


# ----------------------------------------------------------------------------
# MongoDB — Image Storage (GridFS)
# ----------------------------------------------------------------------------
# Used by: docker-compose.yml, docker-compose.dev.yml,
#          docker-compose.monitoring.yml (mongodb-exporter)

# MongoDB root username
MONGO_USER=mongouser

# MongoDB root password
MONGO_PASSWORD=admin123

# Host port mapped to the MongoDB container (default: 27017)
MONGO_PORT=27017


# ----------------------------------------------------------------------------
# Redis — Caching Layer
# ----------------------------------------------------------------------------
# Used by: docker-compose.yml, docker-compose.monitoring.yml (redis-exporter)
# Note: docker-compose.dev.yml runs Redis WITHOUT a password by default.

# Redis authentication password
REDIS_PASSWORD=admin123

# Host port mapped to the Redis container (default: 6379)
REDIS_PORT=6379


# ----------------------------------------------------------------------------
# Seq — Centralized Logging
# ----------------------------------------------------------------------------
# Used by: docker-compose.dev.yml

# Host port mapped to the Seq UI (default: 5341)
SEQ_PORT=5341


# ----------------------------------------------------------------------------
# Web Application (React UI + Nginx Reverse Proxy)
# ----------------------------------------------------------------------------
# Used by: docker-compose.yml

# Host port for the web frontend (default: 5000)
WEB_PORT=5000


# ----------------------------------------------------------------------------
# ASP.NET Core — Application Settings
# ----------------------------------------------------------------------------
# Used by: docker-compose.yml (api, mcpserver)

# Runtime environment: Development | Staging | Production
ASPNETCORE_ENVIRONMENT=Production

# CORS allowed origins — comma-separated list of URLs permitted to call the API
# Update this to match your frontend URL(s). To allow LAN access, add your laptop IP.
# Example: CORS_ALLOWED_ORIGINS=http://localhost:5000,http://192.168.0.109:5000
CORS_ALLOWED_ORIGINS=http://localhost:5000

# JWT secret key for authentication token signing
# MUST be at least 32 characters long. Generate one with:
#   openssl rand -base64 48
JWT_SECRET_KEY=CHANGE_ME_GENERATE_A_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS

# Google OAuth Client ID — obtain from https://console.cloud.google.com/
# Leave blank to disable Google sign-in
GOOGLE_CLIENT_ID=494987898549-14u3p0po6ogtv552vat150jjg5j556j1.apps.googleusercontent.com


# ----------------------------------------------------------------------------
# Monitoring Stack (Grafana + Prometheus)
# ----------------------------------------------------------------------------
# Used by: docker-compose.monitoring.yml

# Grafana admin username (default: admin)
GRAFANA_ADMIN_USER=admin

# Grafana admin password
GRAFANA_ADMIN_PASSWORD=admin123


# ----------------------------------------------------------------------------
# External News API Keys (MCP Server — Background News Fetching)
# ----------------------------------------------------------------------------
# Used by: NewsPortal.McpServer
# These keys are optional for local development but required for
# production news ingestion. Obtain keys from each provider's website.

# NewsAPI.org — https://newsapi.org/register
NEWS_API_KEY=your_newsapi_org_api_key_here

# GNews.io — https://gnews.io/register
GNEWS_API_KEY=your_gnews_io_api_key_here

# Bing Search API (Azure Cognitive Services) —
#   https://www.microsoft.com/en-us/bing/apis/bing-news-search-api
BING_SEARCH_API_KEY=your_bing_search_api_key_here


# ----------------------------------------------------------------------------
# Docker Registry & Image Configuration
# ----------------------------------------------------------------------------
# Used by: CI/CD pipeline (GitHub Actions), deploy.sh, docker-compose.prod.yml

# Container registry hostname (e.g., ghcr.io, docker.io)
DOCKER_REGISTRY=ghcr.io

# Registry username / GitHub username
DOCKER_USERNAME=your_docker_username

# Image tag to pull/push (e.g., latest, v1.0.0, sha-abc1234)
IMAGE_TAG=latest


# ----------------------------------------------------------------------------
# Production Server & Deployment
# ----------------------------------------------------------------------------
# Used by: CI/CD pipeline (GitHub Actions), deploy.sh

# SSH hostname or IP of the production server
SERVER_HOST=your.server.ip.or.hostname

# SSH username on the production server
SERVER_USER=ubuntu

# Public URL of the production site (used for health checks after deploy)
PRODUCTION_URL=https://yourdomain.com
