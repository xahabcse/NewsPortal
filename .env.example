# News Portal Environment Variables
# Copy this file to .env and update with your actual values
# IMPORTANT: Never commit the .env file to version control!

# Application Environment
ASPNETCORE_ENVIRONMENT=Production

# PostgreSQL Database Configuration
POSTGRES_USER=newsadmin
POSTGRES_PASSWORD=YourSecurePassword123_ChangeThis!
POSTGRES_DB=newsportal
POSTGRES_PORT=5432

# MongoDB Configuration
MONGO_USER=mongouser
MONGO_PASSWORD=MongoPassword123_ChangeThis!
MONGO_PORT=27017

# Redis Configuration
REDIS_PORT=6379

# Web Application Port
WEB_PORT=5000

# CORS Configuration
# Comma-separated list of allowed origins for the API
# Example: http://localhost:5000,https://yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:5000

# Optional: API Keys for News Fetching
# NEWS_API_KEY=your_newsapi_key
# GNEWS_API_KEY=your_gnews_key
# BING_SEARCH_API_KEY=your_bing_key

# SECURITY NOTES:
# 1. Change all default passwords before deployment
# 2. Use strong passwords (mix of letters, numbers, symbols)
# 3. Keep this file secure and never commit it to git
# 4. Update CORS_ALLOWED_ORIGINS with your actual frontend URL in production
