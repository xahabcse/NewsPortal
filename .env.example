# News Portal Environment Variables
# Copy this file to .env and update with your actual values
# IMPORTANT: Never commit the .env file to version control!

# Application Environment
ASPNETCORE_ENVIRONMENT=Production

# PostgreSQL Database Configuration
POSTGRES_USER=newsadmin
POSTGRES_PASSWORD=CHANGE_ME_REQUIRED
POSTGRES_DB=newsportal
POSTGRES_PORT=5432

# MongoDB Configuration
MONGO_USER=mongouser
MONGO_PASSWORD=CHANGE_ME_REQUIRED
MONGO_DB=newsportal
MONGO_PORT=27017

# Redis Configuration
REDIS_PASSWORD=CHANGE_ME_REQUIRED
REDIS_PORT=6379

# Seq Logging Admin Password
SEQ_ADMIN_PASSWORD=CHANGE_ME_REQUIRED

# JWT Authentication Secret Key (must be at least 32 characters)
JWT_SECRET_KEY=CHANGE_ME_REQUIRED_MINIMUM_32_CHARACTERS

# Web Application Port
WEB_PORT=5000

# CORS Configuration
# Comma-separated list of allowed origins for the API
# Example: http://localhost:5000,https://yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:5000

# Optional: API Keys for News Fetching
# NEWS_API_KEY=your_newsapi_key
# GNEWS_API_KEY=your_gnews_key
# BING_SEARCH_API_KEY=your_bing_key

# SECURITY NOTES:
# 1. REQUIRED: Change all CHANGE_ME_REQUIRED values before deployment
# 2. Use strong passwords (min 16 chars, mix of letters, numbers, symbols)
# 3. Generate secure passwords: openssl rand -base64 32
# 4. Keep this file secure and NEVER commit .env to git (it's in .gitignore)
# 5. Update CORS_ALLOWED_ORIGINS with your actual frontend URL in production
# 6. For production: Set ASPNETCORE_ENVIRONMENT=Production
