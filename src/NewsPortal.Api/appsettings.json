{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Port=5432;Database=newsportal;Username=newsadmin;Password=REPLACE_WITH_ENV_VAR",
    "MongoDB": "mongodb://mongouser:REPLACE_WITH_ENV_VAR@localhost:27017/newsportal?authSource=admin",
    "Redis": "localhost:6379,abortConnect=false",
    "Seq": "http://localhost:5341"
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "Override": {
      "Microsoft": "Warning",
      "System": "Warning"
    }
  },
  "Cors": {
    "AllowedOrigins": "http://localhost:5000,http://localhost:5173"
  },
  "JwtSettings": {
    "SecretKey": "USE_ENV_VARIABLE_MUST_BE_AT_LEAST_32_CHARACTERS_LONG",
    "Issuer": "NewsPortalAPI",
    "Audience": "NewsPortalClient",
    "ExpirationHours": 24
  }
}